# Copy to the repo root as `.env` on the VPS (72.62.76.198).
# Fill in secrets — never commit the real `.env`.

# --- Server ---
NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# --- Data stores ---
MONGO_URL=mongodb://<user>:<password>@<cluster>.mongodb.net/shelfmerch?ssl=true&authSource=admin
REDIS_URL=redis://127.0.0.1:6379

# --- Auth (min 16 chars each in production) ---
JWT_ACCESS_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-a-long-random-secret>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- File storage ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=shelfmerch.io
STORAGE_DRIVER=auto

